-sm_memory_unit_l1c_access_queue_size                    1 # Size of the access queue to the L1 constant cache at the memory SM structure.Configure to any positive number (default=1)
-sm_memory_unit_l1t_access_queue_size                    1 # Size of the access queue to the L1 texture cache at the memory SM structure.Configure to any positive number (default=1)
