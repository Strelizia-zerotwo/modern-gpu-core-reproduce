-sm_memory_unit_bypass_l1d_directly_go_to_l2_access_queue_size                    1 # Size of the access queue to directly to L2 because is bypassin l1d at the memory SM structure. There is one queue per bank.Configure to any positive number (default=1)
-sm_memory_unit_miscellaneous_access_queue_size                    1 # Size of the access queue to the miscellaneous at the memory SM structure.Configure to any positive number (default=1)
